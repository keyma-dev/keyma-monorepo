{
    "name": "@keyma/cli",
    "version": "0.0.0",
    "description": "Command-line interface for Keyma — project scaffolding and build orchestration",
    "type": "module",
    "main": "./dist/src/index.js",
    "types": "./dist/src/index.d.ts",
    "bin": {
        "keyma": "./dist/src/bin.js"
    },
    "exports": {
        ".": {
            "import": "./dist/src/index.js",
            "types": "./dist/src/index.d.ts"
        }
    },
    "scripts": {
        "build": "tsc && chmod +x dist/src/bin.js",
        "test": "tsc && chmod +x dist/src/bin.js && node --test dist/test/*.test.js"
    },
    "dependencies": {
        "@keyma/compiler": "*",
        "@keyma/core": "*",
        "typescript": "*"
    },
    "peerDependencies": {
        "@keyma/schema": "*",
        "@keyma/ui": "*"
    },
    "peerDependenciesMeta": {
        "@keyma/schema": {
            "optional": true
        },
        "@keyma/ui": {
            "optional": true
        }
    },
    "devDependencies": {
        "@keyma/schema": "*",
        "@keyma/ui": "*",
        "@types/node": "*",
        "typescript": "*"
    },
    "license": "MIT"
}
