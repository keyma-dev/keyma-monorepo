{
  "name": "@keyma/compiler-frontend-ts",
  "version": "0.1.0",
  "description": "TypeScript compiler frontend for Keyma — ingests .ts schema files and produces IR",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "tsc && node --test dist/test/*.test.js"
  },
  "dependencies": {
    "@keyma/ir": "*",
    "typescript": "*"
  },
  "devDependencies": {
    "@types/node": "*",
    "typescript": "*"
  }
}
