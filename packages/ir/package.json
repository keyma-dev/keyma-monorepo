{
  "name": "@keyma/ir",
  "version": "0.0.1",
  "description": "TypeScript types and JSON schema for the Keyma language-neutral IR",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    },
    "./schema.json": "./src/schema.json"
  },
  "files": [
    "dist/src",
    "src/schema.json"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/keyma-dev/keyma-monorepo.git",
    "directory": "packages/ir"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "test": "tsc && node --test dist/test/*.test.js"
  },
  "devDependencies": {
    "typescript": "*"
  },
  "license": "MIT"
}
