{
  "name": "@keyma/formatters",
  "version": "0.0.0",
  "description": "Built-in formatters for Keyma schemas (pure-TS source, compiled into schemas by Keyma)",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "src"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/keyma-dev/keyma-monorepo.git",
    "directory": "packages/formatters"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "test": "tsc --noEmit"
  },
  "dependencies": {
    "@keyma/dsl": "*"
  },
  "devDependencies": {
    "typescript": "*"
  },
  "license": "MIT"
}
