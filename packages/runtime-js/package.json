{
    "name": "@keyma/runtime-js",
    "version": "0.0.0",
    "description": "Tiny runtime consumed by Keyma-generated JavaScript — validate/format/defaults, query builder, server, and adapter interfaces",
    "type": "module",
    "exports": {
        ".": "./dist/src/index.js",
        "./testing": "./dist/src/testing.js"
    },
    "files": [
        "dist/src"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/keyma-dev/keyma-monorepo.git",
        "directory": "packages/runtime-js"
    },
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "tsc",
        "test": "tsc && node --test dist/test/*.test.js"
    },
    "dependencies": {
        "@keyma/dsl": "*"
    },
    "devDependencies": {
        "@types/node": "*",
        "typescript": "*"
    },
    "license": "MIT"
}
