{
  "version": { "kind": "literal", "value": "v1" },
  "baseRate": { "kind": "literal", "value": 0 },
  "isActive": { "kind": "literal", "value": true },
  "greeting": { "kind": "literal", "value": "hello" },
  "displayTitle": { "kind": "field", "name": "title" },
  "summary": {
    "kind": "template",
    "parts": [
      { "kind": "field", "name": "title" },
      { "kind": "literal", "value": ": $" },
      { "kind": "field", "name": "price" }
    ]
  },
  "priceWithTax": {
    "kind": "binary",
    "op": "*",
    "left": { "kind": "field", "name": "price" },
    "right": {
      "kind": "binary",
      "op": "+",
      "left": { "kind": "literal", "value": 1 },
      "right": { "kind": "field", "name": "taxRate" }
    }
  },
  "isExpensive": {
    "kind": "binary",
    "op": ">",
    "left": { "kind": "field", "name": "price" },
    "right": { "kind": "literal", "value": 100 }
  },
  "negatedPrice": {
    "kind": "unary",
    "op": "-",
    "operand": { "kind": "field", "name": "price" }
  },
  "isCheap": {
    "kind": "unary",
    "op": "!",
    "operand": { "kind": "field", "name": "isExpensive" }
  },
  "label": {
    "kind": "conditional",
    "condition": { "kind": "field", "name": "isExpensive" },
    "whenTrue": { "kind": "literal", "value": "premium" },
    "whenFalse": { "kind": "literal", "value": "budget" }
  },
  "displayCategory": {
    "kind": "binary",
    "op": "??",
    "left": { "kind": "field", "name": "category" },
    "right": { "kind": "literal", "value": "uncategorized" }
  },
  "isValidPrice": {
    "kind": "binary",
    "op": "&&",
    "left": {
      "kind": "binary",
      "op": ">",
      "left": { "kind": "field", "name": "price" },
      "right": { "kind": "literal", "value": 0 }
    },
    "right": {
      "kind": "binary",
      "op": ">=",
      "left": { "kind": "field", "name": "taxRate" },
      "right": { "kind": "literal", "value": 0 }
    }
  },
  "hasDiscount": {
    "kind": "binary",
    "op": "||",
    "left": {
      "kind": "binary",
      "op": "<",
      "left": { "kind": "field", "name": "price" },
      "right": { "kind": "literal", "value": 50 }
    },
    "right": {
      "kind": "binary",
      "op": "==",
      "left": { "kind": "field", "name": "taxRate" },
      "right": { "kind": "literal", "value": 0 }
    }
  },
  "tagCount": {
    "kind": "intrinsic",
    "op": "array.length",
    "receiver": { "kind": "field", "name": "tags" },
    "args": []
  },
  "trimmedTitle": {
    "kind": "intrinsic",
    "op": "string.trim",
    "receiver": { "kind": "field", "name": "title" },
    "args": []
  },
  "hasPremiumTag": {
    "kind": "intrinsic",
    "op": "array.includes",
    "receiver": { "kind": "field", "name": "tags" },
    "args": [{ "kind": "literal", "value": "premium" }]
  },
  "tagBadge": {
    "kind": "conditional",
    "condition": {
      "kind": "intrinsic",
      "op": "array.includes",
      "receiver": { "kind": "field", "name": "tags" },
      "args": [{ "kind": "literal", "value": "sale" }]
    },
    "whenTrue": { "kind": "literal", "value": "ON SALE" },
    "whenFalse": { "kind": "literal", "value": "" }
  },
  "priceType": {
    "kind": "typeof",
    "operand": { "kind": "field", "name": "price" }
  }
}
