{
  "name": "@keyma/schema",
  "version": "0.0.1",
  "description": "Keyma schema domain — DSL decorators, IR checks, frontend extraction, and the neutral class-metadata descriptor builder, plus the built-in validator/formatter libraries (one publishable package, subpath exports)",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    },
    "./dsl": {
      "import": "./dist/src/dsl/index.js",
      "types": "./dist/src/dsl/index.d.ts"
    },
    "./ir": {
      "import": "./dist/src/ir/index.js",
      "types": "./dist/src/ir/index.d.ts"
    },
    "./frontend-ts": {
      "import": "./dist/src/frontend-ts/index.js",
      "types": "./dist/src/frontend-ts/index.d.ts"
    },
    "./validators": {
      "types": "./src/validators/index.ts",
      "import": "./src/validators/index.ts"
    },
    "./formatters": {
      "types": "./src/formatters/index.ts",
      "import": "./src/formatters/index.ts"
    }
  },
  "files": [
    "dist/src",
    "dist/src/dsl",
    "dist/src/ir",
    "dist/src/frontend-ts",
    "src/validators",
    "src/formatters"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/keyma-dev/keyma-monorepo.git",
    "directory": "packages/schema"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "gen-types": "node src/scripts/gen-schema-types.mjs",
    "prebuild": "node src/scripts/gen-schema-types.mjs",
    "build": "tsc",
    "pretest": "node src/scripts/gen-schema-types.mjs",
    "test": "tsc && cp -r test/backend-js/snapshots dist/test/backend-js/ && node --test dist/test/dsl/*.test.js dist/test/ir/*.test.js dist/test/frontend-ts/*.test.js dist/test/backend-js/*.test.js dist/test/backend-python/*.test.js dist/test/backend-cpp/ir-type-to-cpp.test.js dist/test/backend-cpp/emit-expression.test.js dist/test/backend-cpp/backend.test.js",
    "test:parity": "tsc && node --test dist/test/parity/*.test.js",
    "test:cpp": "tsc && node --test dist/test/backend-cpp/binary.test.js dist/test/backend-cpp/compile-smoke.test.js"
  },
  "dependencies": {
    "@keyma/core": "^0.0.1",
    "@keyma/compiler": "^0.0.1",
    "typescript": "*"
  },
  "devDependencies": {
    "@keyma/runtime-cpp": "*",
    "@types/node": "*",
    "typescript": "*"
  },
  "license": "MIT"
}
