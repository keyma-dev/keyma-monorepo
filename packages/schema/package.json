{
  "name": "@keyma/schema",
  "version": "0.0.1",
  "description": "Keyma schema domain — DSL decorators, IR checks, frontend extraction, and JS/Python/C++ emitter packs, plus the built-in validator/formatter libraries (one publishable package, subpath exports)",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    },
    "./dsl": {
      "import": "./dist/dsl/src/index.js",
      "types": "./dist/dsl/src/index.d.ts"
    },
    "./ir": {
      "import": "./dist/ir/src/index.js",
      "types": "./dist/ir/src/index.d.ts"
    },
    "./frontend-ts": {
      "import": "./dist/frontend-ts/src/index.js",
      "types": "./dist/frontend-ts/src/index.d.ts"
    },
    "./backend-js": {
      "import": "./dist/backend-js/src/index.js",
      "types": "./dist/backend-js/src/index.d.ts"
    },
    "./backend-python": {
      "import": "./dist/backend-python/src/index.js",
      "types": "./dist/backend-python/src/index.d.ts"
    },
    "./backend-cpp": {
      "import": "./dist/backend-cpp/src/index.js",
      "types": "./dist/backend-cpp/src/index.d.ts"
    },
    "./validators": {
      "types": "./validators/src/index.ts",
      "import": "./validators/src/index.ts"
    },
    "./formatters": {
      "types": "./formatters/src/index.ts",
      "import": "./formatters/src/index.ts"
    }
  },
  "files": [
    "dist/src",
    "dist/dsl/src",
    "dist/ir/src",
    "dist/frontend-ts/src",
    "dist/backend-js/src",
    "dist/backend-python/src",
    "dist/backend-cpp/src",
    "validators/src",
    "formatters/src"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/keyma-dev/keyma-monorepo.git",
    "directory": "packages/schema"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "test": "tsc && cp -r backend-js/test/snapshots dist/backend-js/test/ && node --test dist/dsl/test/*.test.js dist/ir/test/*.test.js dist/frontend-ts/test/*.test.js dist/backend-js/test/*.test.js dist/backend-python/test/*.test.js dist/backend-cpp/test/*.test.js"
  },
  "dependencies": {
    "@keyma/core": "^0.0.1",
    "@keyma/compiler": "^0.0.1",
    "typescript": "*"
  },
  "devDependencies": {
    "@keyma/runtime-cpp": "*",
    "@types/node": "*",
    "typescript": "*"
  },
  "license": "MIT"
}
