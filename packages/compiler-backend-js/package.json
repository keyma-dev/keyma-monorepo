{
    "name": "@keyma/compiler-backend-js",
    "version": "0.0.0",
    "description": "JavaScript backend for Keyma — emits dependency-free client/server JS bundles from IR",
    "type": "module",
    "main": "./dist/src/index.js",
    "exports": {
        ".": "./dist/src/index.js"
    },
    "files": [
        "dist/src"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/keyma-dev/keyma-monorepo.git",
        "directory": "packages/compiler-backend-js"
    },
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "gen-types": "node scripts/gen-emitted-types.mjs",
        "prebuild": "node scripts/gen-emitted-types.mjs",
        "build": "tsc",
        "pretest": "node scripts/gen-emitted-types.mjs",
        "test": "tsc && cp -r test/snapshots dist/test/ && node --test dist/test/*.test.js"
    },
    "dependencies": {
        "@keyma/ir": "*",
        "@keyma/compiler": "*"
    },
    "devDependencies": {
        "@types/node": "*",
        "typescript": "*"
    },
    "license": "MIT"
}
