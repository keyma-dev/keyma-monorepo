{
  "name": "@keyma/compiler",
  "version": "0.0.1",
  "description": "Keyma compiler — driver, TypeScript frontend, and JS/Python/C++ backends (one publishable package, subpath exports)",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/src/driver/index.js",
      "types": "./dist/src/driver/index.d.ts"
    },
    "./frontend-ts": {
      "import": "./dist/src/frontend-ts/index.js",
      "types": "./dist/src/frontend-ts/index.d.ts"
    },
    "./frontend-ts/node": {
      "import": "./dist/src/frontend-ts/node-system.js",
      "types": "./dist/src/frontend-ts/node-system.d.ts"
    },
    "./backend-js": {
      "import": "./dist/src/backend-js/index.js",
      "types": "./dist/src/backend-js/index.d.ts"
    },
    "./backend-python": {
      "import": "./dist/src/backend-python/index.js",
      "types": "./dist/src/backend-python/index.d.ts"
    },
    "./backend-cpp": {
      "import": "./dist/src/backend-cpp/index.js",
      "types": "./dist/src/backend-cpp/index.d.ts"
    }
  },
  "files": [
    "dist/src/driver",
    "dist/src/frontend-ts",
    "dist/src/backend-js",
    "dist/src/backend-python",
    "dist/src/backend-cpp"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/keyma-dev/keyma-monorepo.git",
    "directory": "packages/compiler"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "gen-types": "node src/backend-js/scripts/gen-emitted-types.mjs",
    "gen-runtime": "node src/backend-js/scripts/gen-emitted-runtime.mjs",
    "gen-runtime-header": "node src/backend-cpp/scripts/gen-runtime-header.mjs",
    "prebuild": "node src/backend-js/scripts/gen-emitted-types.mjs && node src/backend-js/scripts/gen-emitted-runtime.mjs && node src/backend-cpp/scripts/gen-runtime-header.mjs",
    "build": "tsc",
    "pretest": "node src/backend-js/scripts/gen-emitted-types.mjs && node src/backend-js/scripts/gen-emitted-runtime.mjs && node src/backend-cpp/scripts/gen-runtime-header.mjs",
    "test": "tsc && node --test \"dist/test/**/*.test.js\""
  },
  "dependencies": {
    "@keyma/core": "^0.0.1",
    "@typescript/vfs": "^1.6.0",
    "typescript": "*"
  },
  "devDependencies": {
    "@keyma/runtime-cpp": "*",
    "@types/node": "*",
    "typescript": "*"
  },
  "license": "MIT"
}
