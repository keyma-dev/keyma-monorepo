{
  "name": "@keyma/ui",
  "version": "0.0.1",
  "private": true,
  "description": "Keyma UI domain (smoke) — proves a second domain plugs into the same four seams (DSL recognition, frontend extraction, IR extensions, JS/Python/C++ emitter packs) without editing @keyma/compiler",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    },
    "./dsl": {
      "import": "./dist/src/dsl/index.js",
      "types": "./dist/src/dsl/index.d.ts"
    },
    "./frontend-ts": {
      "import": "./dist/src/frontend-ts/index.js",
      "types": "./dist/src/frontend-ts/index.d.ts"
    },
    "./backend-js": {
      "import": "./dist/src/backend-js/index.js",
      "types": "./dist/src/backend-js/index.d.ts"
    },
    "./backend-python": {
      "import": "./dist/src/backend-python/index.js",
      "types": "./dist/src/backend-python/index.d.ts"
    },
    "./backend-cpp": {
      "import": "./dist/src/backend-cpp/index.js",
      "types": "./dist/src/backend-cpp/index.d.ts"
    }
  },
  "files": [
    "dist/src",
    "dist/src/dsl",
    "dist/src/frontend-ts",
    "dist/src/backend-js",
    "dist/src/backend-python",
    "dist/src/backend-cpp"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/keyma-dev/keyma-monorepo.git",
    "directory": "packages/ui"
  },
  "scripts": {
    "build": "tsc",
    "test": "tsc && node --test dist/test/dsl/*.test.js dist/test/frontend-ts/*.test.js dist/test/backend-js/*.test.js dist/test/*.test.js"
  },
  "dependencies": {
    "@keyma/core": "^0.0.1",
    "@keyma/compiler": "^0.0.1",
    "typescript": "*"
  },
  "devDependencies": {
    "@keyma/schema": "*",
    "@types/node": "*",
    "typescript": "*"
  },
  "license": "MIT"
}
