{
  "name": "@keyma/core",
  "version": "0.0.1",
  "description": "Keyma core — domain-neutral authoring DSL, language-neutral IR, and browser-safe compiler utilities",
  "type": "module",
  "exports": {
    "./dsl": {
      "import": "./dist/src/dsl/index.js",
      "types": "./dist/src/dsl/index.d.ts"
    },
    "./ir": {
      "import": "./dist/src/ir/index.js",
      "types": "./dist/src/ir/index.d.ts"
    },
    "./ir/schema.json": "./src/ir/schema.json",
    "./util": {
      "import": "./dist/src/util/index.js",
      "types": "./dist/src/util/index.d.ts"
    }
  },
  "files": [
    "dist/src/dsl",
    "dist/src/ir",
    "dist/src/util",
    "src/ir/schema.json"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/keyma-dev/keyma-monorepo.git",
    "directory": "packages/core"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "test": "tsc && node --test 'dist/test/**/*.test.js'"
  },
  "devDependencies": {
    "@types/node": "*",
    "typescript": "*"
  },
  "license": "MIT"
}
