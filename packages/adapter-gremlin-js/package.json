{
    "name": "@keyma/adapter-gremlin-js",
    "version": "0.1.0",
    "type": "module",
    "exports": {
        ".": "./dist/src/index.js"
    },
    "scripts": {
        "build": "tsc",
        "test": "tsc && node --test --test-concurrency=1 --test-timeout=300000 dist/test/*.test.js",
        "gremlin:start": "docker run -d --rm -p 8182:8182 -v \"$PWD/test/tinkergraph-any.properties:/opt/gremlin-server/conf/tinkergraph-empty.properties:ro\" --name keyma-gremlin-test tinkerpop/gremlin-server:3.8.1",
        "gremlin:stop": "docker stop keyma-gremlin-test"
    },
    "peerDependencies": {
        "@keyma/runtime-js": "*",
        "gremlin": "^3.8.1"
    },
    "devDependencies": {
        "@keyma/runtime-js": "*",
        "@types/gremlin": "^3.6.0",
        "@types/node": "*",
        "gremlin": "^3.8.0",
        "typescript": "*"
    },
    "license": "MIT"
}
