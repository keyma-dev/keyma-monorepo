{
    "name": "@keyma/compiler-backend-cpp",
    "version": "0.0.0",
    "description": "C++23 backend for Keyma — emits header-only C++ model modules from IR",
    "type": "module",
    "main": "./dist/src/index.js",
    "exports": {
        ".": "./dist/src/index.js"
    },
    "files": [
        "dist/src"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/keyma-dev/keyma-monorepo.git",
        "directory": "packages/compiler-backend-cpp"
    },
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "gen-runtime-header": "node scripts/gen-runtime-header.mjs",
        "prebuild": "node scripts/gen-runtime-header.mjs",
        "build": "tsc",
        "pretest": "node scripts/gen-runtime-header.mjs",
        "test": "tsc && node --test dist/test/*.test.js"
    },
    "dependencies": {
        "@keyma/ir": "*",
        "@keyma/compiler": "*"
    },
    "devDependencies": {
        "@keyma/runtime-cpp": "*",
        "@types/node": "*",
        "typescript": "*"
    },
    "license": "MIT"
}
