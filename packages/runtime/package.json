{
    "name": "@keyma/runtime",
    "version": "0.0.1",
    "description": "Keyma JS/TS runtime — authored source-of-truth + test bed for the model codec and @Service RPC stack the compiler bakes into self-contained generated bundles (never imported by generated code)",
    "type": "module",
    "exports": {
        ".": "./dist/src/index.js"
    },
    "files": [
        "dist/src"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/keyma-dev/keyma-monorepo.git",
        "directory": "packages/runtime"
    },
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "tsc",
        "test": "tsc && node --test dist/test/*.test.js"
    },
    "devDependencies": {
        "@types/node": "*",
        "typescript": "*"
    },
    "license": "MIT"
}
